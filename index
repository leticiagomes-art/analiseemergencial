const BUCKET_ORDER = ['0-1 dias','2-3 dias','4-7 dias','8-15 dias','16-30 dias','30-44 dias','45+ dias'];

function renderProductDetail(productName) {
  const intervalData = DATA.intervals[productName];
  if (!intervalData) {
    document.getElementById('detail-bucket').innerHTML = '<div style="color:var(--text-faint);font-size:11px;">Sem dados</div>';
    document.getElementById('detail-reasons').innerHTML = '<div style="color:var(--text-faint);font-size:11px;">Sem dados</div>';
    document.getElementById('detail-offertype').innerHTML = '<div style="color:var(--text-faint);font-size:11px;">Sem dados</div>';
    return;
  }
  const mode = currentMode;
  const d = intervalData[mode];

  // bucket bars
  const total = d.total || 1;
  const bucketHtml = BUCKET_ORDER.map(b => {
    const v = d.by_bucket[b] || 0;
    const pct = (v/total*100);
    return `<div class="bar-row">
      <div class="label">${b}</div>
      <div class="track"><div class="fill" style="width:${pct}%; background:${mode==='chargeback'?COLORS.red:COLORS.accent}"></div></div>
      <div class="val">${v}</div>
    </div>`;
  }).join('');
  document.getElementById('detail-bucket').innerHTML = bucketHtml || '<div style="color:var(--text-faint);font-size:11px;">Sem ocorrências</div>';

  // reasons
  const reasons = Object.entries(d.by_reason || {});
  const reasonHtml = reasons.length ? reasons.map(([reason, count]) => {
    const shortReason = reason.length > 42 ? reason.slice(0,42) + '…' : reason;
    return `<div class="reason-row"><div class="reason-text" title="${reason.replace(/"/g,'&quot;')}">${shortReason}</div><div class="reason-count">${count}</div></div>`;
  }).join('') : '<div style="color:var(--text-faint);font-size:11px;">Sem ocorrências</div>';
  document.getElementById('detail-reasons').innerHTML = reasonHtml;

  // offer type
  const offerOrder = ['Pedido Principal','Upsell','Downsell','Shipping/Outro','Indefinido'];
  const offerColors = { 'Pedido Principal': COLORS.accent, 'Upsell': COLORS.red, 'Downsell': COLORS.amber, 'Shipping/Outro': COLORS.faint, 'Indefinido': COLORS.faint };
  const offerHtml = offerOrder.filter(o => (d.by_offer_type[o]||0) > 0).map(o => {
    const v = d.by_offer_type[o] || 0;
    const pct = (v/total*100);
    return `<div class="bar-row">
      <div class="label">${o}</div>
      <div class="track"><div class="fill" style="width:${pct}%; background:${offerColors[o]}"></div></div>
      <div class="val">${v}</div>
    </div>`;
  }).join('');
  document.getElementById('detail-offertype').innerHTML = offerHtml || '<div style="color:var(--text-faint);font-size:11px;">Sem ocorrências</div>';
}

