function renderSummaryCards(aff) {
  // Blame
  let bi=0,ba=0,bm=0,bu=0;
  aff.forEach(a => { bi+=a.blame.pct_internal/100; ba+=a.blame.pct_affiliate/100; bm+=a.blame.pct_mixed/100; });
  const bt=aff.length||1;
  const blameHtml = [
    {label:'Interna (oferta/plataforma)',val:Math.round(bi/bt*100),color:COLORS.accent},
    {label:'Afiliado (funil/tráfego)',val:Math.round(ba/bt*100),color:COLORS.red},
    {label:'Misto / Indefinido',val:Math.round(bm/bt*100),color:COLORS.amber},
  ].map(x=>`<div class="bar-row"><div class="label" style="width:160px;">${x.label}</div><div class="track"><div class="fill" style="width:${x.val}%;background:${x.color}"></div></div><div class="val">${x.val}%</div></div>`).join('');
  document.getElementById('summary-blame').innerHTML = blameHtml;

  // Offer type
  let front=0,up=0,down=0;
  aff.forEach(a=>{ front+=a.offer.rf_front+a.offer.cb_front; up+=a.offer.rf_upsell+a.offer.cb_upsell; });
  const ot=front+up||1;
  const offerHtml = [
    {label:'Front-end',val:Math.round(front/ot*100),color:COLORS.accent},
    {label:'Upsell',val:Math.round(up/ot*100),color:COLORS.red},
  ].map(x=>`<div class="bar-row"><div class="label" style="width:80px;">${x.label}</div><div class="track"><div class="fill" style="width:${x.val}%;background:${x.color}"></div></div><div class="val">${x.val}%</div></div>`).join('');
  document.getElementById('summary-offer').innerHTML = offerHtml;

  // Timing
  const tc={};
  aff.forEach(a=>Object.entries(a.timing.buckets).forEach(([k,v])=>{ tc[k]=(tc[k]||0)+v; }));
  const tm=Object.values(tc).reduce((a,b)=>a+b,1);
  const timingHtml = BUCKET_ORDER_SHORT.filter(b=>tc[b]).map(b=>`<div class="bar-row"><div class="label" style="width:80px;">${b}</div><div class="track"><div class="fill" style="width:${Math.round(tc[b]/tm*100)}%;background:${b==='0-1d'?COLORS.red:COLORS.amber}"></div></div><div class="val">${tc[b]}</div></div>`).join('');
  document.getElementById('summary-timing').innerHTML = timingHtml||'<span style="color:var(--text-faint)">Sem dados</span>';
}

function blameSignal(a) {
  const d = a.blame.detail;
  const keys = Object.keys(d).sort((x,y)=>d[y]-d[x]);
  if (!keys.length) return '—';
  return keys.slice(0,2).map(k => {
    const color = k.startsWith('Interna') ? COLORS.accent : k.startsWith('Afiliado') ? COLORS.red : COLORS.amber;
    return `<span style="color:${color};font-size:10.5px;">${k} (${d[k]})</span>`;
  }).join('<br>');
}

function renderAlertCards() {
  const aff = getFilteredAffiliates();
  const container = document.getElementById('alert-cards-container');
  if (!aff.length) { container.innerHTML = '<div style="color:var(--text-faint);padding:20px;text-align:center;">Nenhum afiliado nesta categoria.</div>'; return; }

  renderSummaryCards(aff);

  // Group by tier
  const tops = aff.filter(a=>a.tier==='TOP');
  const commons = aff.filter(a=>a.tier==='Comum');

  function buildSection(list, title, subtitle) {
    if (!list.length) return '';
    const cards = list.map(a => {
      const sc = STATUS_CONFIG[a.status]||STATUS_CONFIG['OK'];
      const tierBadge = a.tier==='TOP'
        ? `<span style="background:#fef3c7;color:#d97706;font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:5px;margin-left:6px;">⭐ TOP</span>`
        : `<span style="background:var(--card-bg-2);color:var(--text-faint);font-size:9.5px;padding:2px 7px;border-radius:5px;margin-left:6px;">Comum</span>`;

      const ratePct = a.rate_pct !== null ? a.rate_pct : '—';
      const rateColor = a.rate_pct >= 35 ? COLORS.red : a.rate_pct >= 15 ? COLORS.amber : COLORS.green;
      const upPct = a.offer.pct_upsell;
      const upColor = upPct >= 50 ? COLORS.red : upPct >= 30 ? COLORS.amber : COLORS.faint;

      const blameBar = () => {
        const {pct_internal:pi, pct_affiliate:pa, pct_mixed:pm} = a.blame;
        return `<div style="display:flex;height:6px;border-radius:3px;overflow:hidden;margin:4px 0 8px;">
          <div style="width:${pi}%;background:${COLORS.accent}"></div>
          <div style="width:${pa}%;background:${COLORS.red}"></div>
          <div style="width:${pm}%;background:${COLORS.amber}"></div>
        </div>
        <div style="display:flex;gap:6px;font-size:9.5px;color:var(--text-faint);">
          <span style="color:${COLORS.accent}">■ Interna ${pi}%</span>
          <span style="color:${COLORS.red}">■ Afiliado ${pa}%</span>
          <span style="color:${COLORS.amber}">■ Misto ${pm}%</span>
        </div>`;
      };

      const timingBuckets = BUCKET_ORDER_SHORT.filter(b=>a.timing.buckets[b]).map(b => {
        const v = a.timing.buckets[b];
        const total = Object.values(a.timing.buckets).reduce((s,x)=>s+x,1);
        const pct = Math.round(v/total*100);
        const color = b==='0-1d'?COLORS.red:b==='2-3d'?COLORS.amber:COLORS.accent;
        return `<div style="display:flex;align-items:center;gap:5px;margin-bottom:3px;font-size:10px;">
          <span style="width:48px;color:var(--text-faint);">${b}</span>
          <div style="flex:1;background:var(--border);border-radius:2px;height:10px;overflow:hidden;">
            <div style="width:${pct}%;height:100%;background:${color};border-radius:2px;"></div>
          </div>
          <span style="width:24px;text-align:right;font-weight:600;">${v}</span>
        </div>`;
      }).join('');

      const prods = Object.entries(a.top_products).map(([p,n])=>`<span style="font-size:10px;background:var(--card-bg-2);padding:2px 6px;border-radius:4px;margin:1px;">${p} (${n})</span>`).join(' ');

      const topBlameKeys = Object.entries(a.blame.detail).sort((x,y)=>y[1]-x[1]).slice(0,3);
      const blameDetail = topBlameKeys.map(([k,v])=>{
        const color = k.startsWith('Interna')?COLORS.accent:k.startsWith('Afiliado')?COLORS.red:COLORS.amber;
        const short = k.replace('Interna — ','').replace('Afiliado — ','').replace('Misto — ','');
        return `<div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid var(--border);font-size:10.5px;">
          <span style="color:${color};">${short}</span>
          <span style="font-weight:700;color:var(--text);">${v}</span>
        </div>`;
      }).join('');

      return `<div style="background:var(--bg-panel,#fff);border:1px solid var(--border);border-radius:12px;padding:16px 18px;position:relative;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
          <div>
            <div style="font-weight:700;font-size:14px;">${a.name}${tierBadge}</div>
            <div style="font-size:11px;color:var(--text-faint);margin-top:2px;font-family:var(--mono);">ID ${a.aff_id} · ${a.orders!==null?a.orders+' pedidos':'volume não mapeado'}</div>
          </div>
          <div style="text-align:right;">
            <span class="status-tag ${sc.cls}">${sc.icon} ${a.status}</span>
            <div style="font-family:var(--mono);font-size:18px;font-weight:700;color:${rateColor};margin-top:4px;">${a.rate_pct!==null?a.rate_pct.toFixed(1)+'%':'—'}</div>
            <div style="font-size:9.5px;color:var(--text-faint);">refund+CB/vendas</div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1.2fr;gap:12px;margin-bottom:12px;">
          <div>
            <div style="font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-faint);margin-bottom:6px;">Pedido principal × upsell</div>
            <div style="font-size:12px;font-weight:600;color:${upColor};">↑ ${upPct}% Upsell</div>
            <div style="font-size:10.5px;color:var(--text-faint);">RF: ${a.offer.rf_front}FE + ${a.offer.rf_upsell}UP | CB: ${a.offer.cb_front}FE + ${a.offer.cb_upsell}UP</div>
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-faint);margin-bottom:4px;">Culpa interna × afiliado</div>
            ${blameBar()}
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-faint);margin-bottom:6px;">Motivos (top 3)</div>
            ${blameDetail}
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div>
            <div style="font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-faint);margin-bottom:6px;">Intervalo até reembolso (avg: ${a.timing.avg_days_rf !== null ? a.timing.avg_days_rf+'d' : '—'})</div>
            ${timingBuckets||'<span style="font-size:10px;color:var(--text-faint)">Sem dados</span>'}
          </div>
          <div>
            <div style="font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-faint);margin-bottom:6px;">Produtos com mais RF (60d)</div>
            <div style="line-height:1.8;">${prods||'—'}</div>
            <div style="margin-top:8px;font-size:10.5px;color:var(--text-faint);">RF: ${a.qtd_rf} reembolsos ($${fmtNum(a.val_rf)}) · CB: ${a.qtd_cb} ($${fmtNum(a.val_cb)})</div>
          </div>
        </div>
      </div>`;
    }).join('');

    return `<div style="margin-bottom:20px;">
      <div style="font-size:13.5px;font-weight:700;color:var(--text);padding:10px 0 8px;border-bottom:1px solid var(--border-strong);margin-bottom:12px;">${title} <span style="font-size:11px;color:var(--text-faint);font-weight:400;">${subtitle}</span></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">${cards}</div>
    </div>`;
  }

  container.innerHTML =
    buildSection(tops, '⭐ Afiliados TOP (90+ vendas/mês)', tops.length + ' afiliados') +
    buildSection(commons, '👤 Afiliados Comuns com alto impacto', commons.length + ' afiliados com 3+ eventos de refund/CB');
}

