  const refundDelta = pctDelta(d28.refund_val, d29.refund_val);
  const items = [
    { label: 'Faturamento 29/06', value: fmtUSD(d29.faturamento), delta: fatDelta, invert:false },
    { label: 'Reembolso 29/06', value: fmtUSD(d29.refund_val), delta: refundDelta, invert:true },
    { label: 'Refund % do dia', value: fmtPct(d29.refund_pct), delta: d29.refund_pct - d28.refund_pct, invert:true, isPct:true },
    { label: 'Net profit 29/06', value: fmtUSD(d29.net_profit), delta: pctDelta(d28.net_profit, d29.net_profit), invert:false },
  ];
  document.getElementById('kpi-lastweek').innerHTML = items.map(it => {
    let deltaHtml;
    if (it.isPct) {
      const good = it.invert ? it.delta < 0 : it.delta > 0;
      const cls = Math.abs(it.delta) < 0.3 ? 'flat' : (good ? 'up' : 'down');
      const arrow = it.delta > 0 ? '▲' : (it.delta < 0 ? '▼' : '—');
      deltaHtml = `<span class="kpi-delta ${cls}">${arrow} ${Math.abs(it.delta).toFixed(1)}pp vs 28/06</span>`;
    } else {
      deltaHtml = deltaTag(it.delta, it.invert).replace('vs maio', 'vs 28/06');
    }
    return `<div class="kpi"><div class="kpi-label">${it.label}</div><div class="kpi-value">${it.value}</div>${deltaHtml}</div>`;
  }).join('');
}

