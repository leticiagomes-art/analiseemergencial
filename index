function renderProfitGrowthChart() {
  const order = ['BreathEaseX','NervoLyn','AudiLeaf','Prostafense','VisiumPro','GlucoRecover','MaroBrain'];
  const w = 760, groupW = 90, barW = 30, gap = 8, padL = 50, padT = 16, padB = 36;
  const h = 280;
  const maio = DATA.products.maio, junho = DATA.products.junho;
  const maxV = Math.max(...order.map(n => Math.max(maio[n]?.faturamento||0, junho[n]?.faturamento||0))) * 1.1;
  const yScale = v => padT + (h-padT-padB) - (v/maxV)*(h-padT-padB);

  let svg = `<svg class="chart" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;
  for (let i=0;i<=4;i++){
    const v = maxV*(i/4);
    const y = yScale(v);
    svg += `<line class="grid-line" x1="${padL}" x2="${w-10}" y1="${y}" y2="${y}"/>`;
    svg += `<text class="axis-label" x="${padL-8}" y="${y+3}" text-anchor="end">${fmtUSDk(v)}</text>`;
  }
  order.forEach((name,i) => {
    const gx = padL + i*groupW + 20;
    const m = maio[name], j = junho[name];
    const mH = (h-padT-padB) - (yScale(m?.faturamento||0) - padT);
    const jH = (h-padT-padB) - (yScale(j?.faturamento||0) - padT);
    svg += `<rect x="${gx}" y="${yScale(m?.faturamento||0)}" width="${barW}" height="${mH}" fill="#9aa3b2" rx="2" data-tip="Maio: ${fmtUSD(m?.faturamento||0)}"/>`;
    svg += `<rect x="${gx+barW+4}" y="${yScale(j?.faturamento||0)}" width="${barW}" height="${jH}" fill="${COLORS.accent}" rx="2" data-tip="Junho: ${fmtUSD(j?.faturamento||0)}"/>`;
    svg += `<text class="axis-label" x="${gx+barW}" y="${h-14}" text-anchor="middle" font-size="9.5">${name}</text>`;
  });
  svg += `</svg>`;
  const container = document.getElementById('chart-profit-growth');
  container.innerHTML = `<div class="legend" style="margin-bottom:10px;"><div class="legend-item"><span class="legend-swatch" style="background:#9aa3b2"></span>Maio</div><div class="legend-item"><span class="legend-swatch" style="background:${COLORS.accent}"></span>Junho</div></div>` + svg;
  container.querySelectorAll('rect').forEach(r => {
    r.addEventListener('mouseenter', e => showTip(r.dataset.tip, e.clientX, e.clientY));
    r.addEventListener('mousemove', e => showTip(r.dataset.tip, e.clientX, e.clientY));
    r.addEventListener('mouseleave', hideTip);
  });
}

