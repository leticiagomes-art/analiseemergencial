function renderLastWeekTable() {
  const lw = DATA.last_week.daily;
  const days = ['23','24','26','27','28','29'];
  let html = '<thead><tr><th>Dia</th><th class="num">Vendas</th><th class="num">Faturamento</th><th class="num">Δ Faturamento</th><th class="num">Reembolso $</th><th class="num">Δ Reembolso</th><th class="num">Refund %</th><th class="num">Net Profit</th><th class="num">Margem</th></tr></thead><tbody>';
  let prevFat = null, prevRef = null;
  days.forEach(k => {
    const d = lw[k];
    const fatD = prevFat === null ? '—' : (((d.faturamento-prevFat)/prevFat*100).toFixed(1)+'%');
    const refD = prevRef === null ? '—' : (((d.refund_val-prevRef)/prevRef*100).toFixed(1)+'%');
    const isWorst = k === '29';
    html += `<tr style="${isWorst?'background:rgba(226,85,74,0.06);font-weight:600;':''}">
      <td>${d.date}${isWorst?' ⚠️':''}</td>
      <td class="num">${fmtNum(d.vendas)}</td>
      <td class="num">${fmtUSD(d.faturamento)}</td>
      <td class="num" style="color:${prevFat!==null && d.faturamento<prevFat?COLORS.red:COLORS.green}">${fatD}</td>
      <td class="num">${fmtUSD(d.refund_val)}</td>
      <td class="num" style="color:${prevRef!==null && d.refund_val>prevRef?COLORS.red:COLORS.green}">${refD}</td>
      <td class="num" style="color:${d.refund_pct>25?COLORS.red:(d.refund_pct>15?COLORS.amber:COLORS.green)}">${fmtPct(d.refund_pct)}</td>
      <td class="num">${fmtUSD(d.net_profit)}</td>
      <td class="num">${fmtPct(d.margem)}</td>
    </tr>`;
    prevFat = d.faturamento;
    prevRef = d.refund_val;
  });
  html += '</tbody>';
  document.getElementById('table-lastweek').innerHTML = html;
}

// ============ AFFILIATE ALERTS VIEW ============
const STATUS_CONFIG = {
  'Em alerta':          { cls: 'status-alert', icon: '🔴' },
  'Em acompanhamento':  { cls: 'status-watch', icon: '🟡' },
  'OK':                 { cls: 'status-ok',    icon: '✅' },
};

const BUCKET_ORDER_SHORT = ['0-1d','2-3d','4-7d','8-15d','16-30d','31-44d','45+d'];
const BUCKET_LABEL = {'0-1d':'0–1 dia','2-3d':'2–3 dias','4-7d':'4–7 dias','8-15d':'8–15 dias','16-30d':'16–30 dias','31-44d':'31–44 dias','45+d':'45+ dias','Indefinido':'Indefinido'};
const BLAME_COLOR = {'Interna':COLORS.accent,'Afiliado':COLORS.red,'Misto':COLORS.amber};

let affFilter = 'alert';
let affTier = 'all';

function getFilteredAffiliates() {
  let aff = DATA.affiliate_detail.affiliates;
  if (affTier !== 'all') aff = aff.filter(a => a.tier === affTier);
  if (affFilter === 'alert') aff = aff.filter(a => a.status === 'Em alerta');
  else if (affFilter === 'watch') aff = aff.filter(a => a.status === 'Em acompanhamento');
  else if (affFilter === 'ok') aff = aff.filter(a => a.status === 'OK');
  return aff.sort((a,b) => (b.qtd_rf+b.qtd_cb) - (a.qtd_rf+a.qtd_cb));
}

function renderAffAlertsKPIs() {
  const all = DATA.affiliate_detail.affiliates;
  const totalAlert = all.filter(a => a.status==='Em alerta').length;
  const totalWatch = all.filter(a => a.status==='Em acompanhamento').length;
  const totalOk = all.filter(a => a.status==='OK').length;
  const topAlert = all.filter(a => a.tier==='TOP' && a.status==='Em alerta').length;
  const items = [
    { label: 'Em alerta (total)', value: totalAlert, color: COLORS.red },
    { label: 'Em acompanhamento', value: totalWatch, color: COLORS.amber },
