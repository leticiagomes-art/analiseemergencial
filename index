// ============ HELPERS: SVG LINE CHART ============
function buildLineChart(container, series, opts) {
  const w = opts.width || 760, h = opts.height || 280;
  const padL = 56, padR = 20, padT = 16, padB = 32;
  const innerW = w - padL - padR, innerH = h - padT - padB;

  const allY = series.flatMap(s => s.points.map(p => p.y));
  const yMin = opts.yMin !== undefined ? opts.yMin : Math.min(0, Math.min(...allY));
  const yMax = opts.yMax !== undefined ? opts.yMax : Math.max(...allY) * 1.15;
  const xLabels = series[0].points.map(p => p.label);
  const n = xLabels.length;

  const xScale = i => padL + (n === 1 ? innerW/2 : (i / (n-1)) * innerW);
  const yScale = v => padT + innerH - ((v - yMin) / (yMax - yMin || 1)) * innerH;

  let svg = `<svg class="chart" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;

  const gridSteps = 4;
  for (let i = 0; i <= gridSteps; i++) {
    const v = yMin + (yMax - yMin) * (i / gridSteps);
    const y = yScale(v);
    svg += `<line class="grid-line" x1="${padL}" x2="${w-padR}" y1="${y}" y2="${y}"/>`;
    svg += `<text class="axis-label" x="${padL-8}" y="${y+3}" text-anchor="end">${opts.yFmt ? opts.yFmt(v) : Math.round(v)}</text>`;
  }
  xLabels.forEach((lab, i) => {
    svg += `<text class="axis-label" x="${xScale(i)}" y="${h-8}" text-anchor="middle">${lab}</text>`;
  });

  series.forEach(s => {
    const pts = s.points.map((p,i) => `${xScale(i)},${yScale(p.y)}`).join(' ');
    if (s.area) {
      const areaPts = `${padL},${yScale(yMin)} ` + pts + ` ${xScale(n-1)},${yScale(yMin)}`;
      svg += `<polygon class="chart-area" points="${areaPts}" fill="${s.color}"/>`;
    }
    svg += `<polyline class="chart-line" points="${pts}" stroke="${s.color}"/>`;
    s.points.forEach((p,i) => {
      svg += `<circle class="chart-dot" cx="${xScale(i)}" cy="${yScale(p.y)}" r="4" fill="${s.color}" data-tip="${(s.label?s.label+': ':'')+(p.fmtY||p.y)}"/>`;
    });
  });

  svg += `</svg>`;
  container.innerHTML = svg;

  container.querySelectorAll('circle').forEach(c => {
    c.addEventListener('mouseenter', e => { c.setAttribute('r', 6); showTip(c.dataset.tip, e.clientX, e.clientY); });
    c.addEventListener('mousemove', e => showTip(c.dataset.tip, e.clientX, e.clientY));
    c.addEventListener('mouseleave', () => { c.setAttribute('r',4); hideTip(); });
  });
}

function buildBarChart(container, items, opts) {
  const w = opts.width || 760;
  const barH = opts.barH || 26, gap = opts.gap || 10;
  const padL = opts.padL || 130, padR = 60, padT = 8;
  const h = items.length * (barH + gap) + padT;
  const innerW = w - padL - padR;
  const maxV = opts.max || Math.max(...items.map(i => Math.abs(i.value))) * 1.1;

  let svg = `<svg class="chart" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;
  items.forEach((item, i) => {
    const y = padT + i * (barH + gap);
    const barW = Math.max(2, (item.value / maxV) * innerW);
    svg += `<text class="axis-label" x="${padL-10}" y="${y+barH/2+4}" text-anchor="end" fill="#1a1f29" font-size="11">${item.label}</text>`;
    svg += `<rect x="${padL}" y="${y}" width="${innerW}" height="${barH}" fill="#f1f3f6" rx="3"/>`;
    svg += `<rect class="bar-anim" x="${padL}" y="${y}" width="${barW}" height="${barH}" fill="${item.color}" rx="3" data-tip="${item.sublabel || item.value}"/>`;
    svg += `<text class="axis-label" x="${padL+barW+8}" y="${y+barH/2+4}" fill="#1a1f29" font-size="11" font-family="JetBrains Mono">${item.valueLabel !== undefined ? item.valueLabel : item.value}</text>`;
  });
  svg += `</svg>`;
  container.innerHTML = svg;

  container.querySelectorAll('.bar-anim').forEach(b => {
    b.addEventListener('mouseenter', e => showTip(b.dataset.tip, e.clientX, e.clientY));
    b.addEventListener('mousemove', e => showTip(b.dataset.tip, e.clientX, e.clientY));
    b.addEventListener('mouseleave', hideTip);
  });
}

// ============ KPI: OVERVIEW ============
function pctDelta(a, b) { return ((b - a) / a) * 100; }
function deltaTag(delta, invert) {
  const good = invert ? delta < 0 : delta > 0;
  const cls = Math.abs(delta) < 0.5 ? 'flat' : (good ? 'up' : 'down');
  const arrow = delta > 0 ? '▲' : (delta < 0 ? '▼' : '—');
  return `<span class="kpi-delta ${cls}">${arrow} ${Math.abs(delta).toFixed(1)}% vs maio</span>`;
}

function renderOverviewKPIs() {
  const maio = DATA.periods.maio, junho = DATA.periods.junho;
  const refMaio = DATA.platform.maio, refJunho = DATA.platform.junho;
  const items = [
    { label: 'Faturamento — Junho', value: fmtUSD(junho.faturamento), delta: pctDelta(maio.faturamento, junho.faturamento), invert:false },
    { label: 'Volume de Vendas', value: fmtNum(junho.vendas), delta: pctDelta(maio.vendas, junho.vendas), invert:false },
    { label: 'Refund % (BuyGoods)', value: fmtPct(refJunho.refund_pct), delta: refJunho.refund_pct - refMaio.refund_pct, invert:true, isPct:true },
    { label: 'Net Profit', value: fmtUSD(junho.net_profit), delta: pctDelta(maio.net_profit, junho.net_profit), invert:false },
    { label: 'Margem Líquida', value: fmtPct(junho.margem), delta: junho.margem - maio.margem, invert:false, isPct:true },
  ];
  const html = items.map(it => {
    let deltaHtml;
    if (it.isPct) {
      const good = it.invert ? it.delta < 0 : it.delta > 0;
      const cls = Math.abs(it.delta) < 0.3 ? 'flat' : (good ? 'up' : 'down');
      const arrow = it.delta > 0 ? '▲' : (it.delta < 0 ? '▼' : '—');
      deltaHtml = `<span class="kpi-delta ${cls}">${arrow} ${Math.abs(it.delta).toFixed(1)}pp vs maio</span>`;
    } else {
      deltaHtml = deltaTag(it.delta, it.invert);
    }
    return `<div class="kpi"><div class="kpi-label">${it.label}</div><div class="kpi-value">${it.value}</div>${deltaHtml}</div>`;
  }).join('');
  document.getElementById('kpi-overview').innerHTML = html;
}

